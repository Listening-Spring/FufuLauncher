<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="FufuLauncher.Views.LoginQrWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Title="{helpers:Loc Key=LoginQR_Title}">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid PreviewKeyDown="RootGrid_PreviewKeyDown">
        <Grid.Resources>
            <Storyboard x:Name="QrCodeFadeInStoryboard">
                <DoubleAnimation Storyboard.TargetName="QrCodeImage"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0" Duration="0:0:0.5" />
            </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" x:FieldModifier="public" Grid.Row="0" Background="Transparent">
            <TextBlock Text="{helpers:Loc Key=LoginQR_Title}" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14" Opacity="0.8" />
        </Grid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <ComboBox x:Name="LoginMethodComboBox" SelectedIndex="0" HorizontalAlignment="Center"
                      SelectionChanged="LoginMethodComboBox_SelectionChanged">
                <ComboBoxItem Content="{helpers:Loc Key=LoginQR_MiyousheQR}" />
                <ComboBoxItem Content="{helpers:Loc Key=LoginQR_WebPassport}" />
                <ComboBoxItem Content="{helpers:Loc Key=LoginQR_HoYoLABWeb}" />
            </ComboBox>

            <StackPanel x:Name="GameLoginPanel" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="{helpers:Loc Key=LoginQR_GameAppId}" VerticalAlignment="Center" />
                <TextBox x:Name="GameAppIdTextBox" Text="7" Width="100" PlaceholderText="{helpers:Loc Key=LoginQR_EnterAppId}" />
                <Button Content="{helpers:Loc Key=LoginQR_ConfirmGenerate}" Click="GameLoginButton_Click" />
            </StackPanel>

            <StackPanel x:Name="QrCodeContainer" Spacing="20">
                <Border Width="220" Height="220" Background="White" CornerRadius="8" Padding="10"
                        HorizontalAlignment="Center">
                    <Image x:Name="QrCodeImage" Stretch="Uniform" Opacity="0" />
                </Border>
                <Button x:Name="RefreshButton" Content="{helpers:Loc Key=LoginQR_RefreshQR}" Click="RefreshButton_Click" HorizontalAlignment="Center" />
            </StackPanel>

            <Grid x:Name="PassportWebViewBorder" Visibility="Collapsed" HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" MinWidth="420" MinHeight="480">

                <WebView2 x:Name="PassportWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Grid IsHitTestVisible="False">
                    <Path Data="M 0,12 A 12,12 0 0 1 12,0 L 0,0 Z"
                          Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                          HorizontalAlignment="Left" VerticalAlignment="Top" />
                    <Path Data="M 0,0 A 12,12 0 0 1 12,12 L 12,0 Z"
                          Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                          HorizontalAlignment="Right" VerticalAlignment="Top" />
                    <Path Data="M 12,12 A 12,12 0 0 1 0,0 L 0,12 Z"
                          Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                    <Path Data="M 12,0 A 12,12 0 0 1 0,12 L 12,12 Z"
                          Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                          HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                </Grid>
            </Grid>

            <TextBlock x:Name="WebLoginWarningTextBlock"
                       Text="{helpers:Loc Key=LoginQR_WebLoginWarning}"
                       Foreground="DarkOrange"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed" />

            <Button x:Name="ManualCookieButton" Content="{helpers:Loc Key=LoginQR_ManualCookie}" Click="ManualCookieButton_Click"
                    HorizontalAlignment="Center" />
            <Button x:Name="ClearCacheButton" Content="{helpers:Loc Key=LoginQR_ClearHistory}" Click="ClearCacheButton_Click"
                    HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>