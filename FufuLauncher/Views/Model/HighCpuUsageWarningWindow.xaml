<Window
    x:Class="FufuLauncher.Views.HighCpuUsageWarningWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="性能异常提示">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="36" Background="Transparent">
            <TextBlock Text="性能异常提示" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" Opacity="0.8"/>
        </Grid>

        <Grid Grid.Row="1" Padding="32,20,32,32">
            <Border Padding="28" CornerRadius="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="56" Height="56" CornerRadius="18" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                            <FontIcon Glyph="&#xE7BA;" FontSize="26" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="检测到长期异常的资源占用" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="UsageText" FontSize="13" Opacity="0.72" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="在未检测到 OBS 正在运行的情况下，芙芙启动器的 CPU 占用已持续高于 30% 达 5 分钟。这通常不是正常现象。" FontSize="14" LineHeight="22" TextWrapping="Wrap" Opacity="0.86"/>

                    <Border Grid.Row="2" Padding="16" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="建议操作" FontWeight="SemiBold"/>
                            <TextBlock Text="请优先汇报问题以帮助定位；如果当前版本持续异常，建议退出使用并更新到最新版本。" FontSize="13" Opacity="0.76" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3" ColumnSpacing="12" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="稍后处理" MinWidth="96" Click="OnDismissClick"/>
                        <Button Grid.Column="1" Content="汇报问题" MinWidth="104" Style="{StaticResource AccentButtonStyle}" Click="OnFeedbackClick"/>
                        <Button Grid.Column="2" Content="退出启动器" MinWidth="104" Click="OnExitClick"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
