<Window
    x:Class="FufuLauncher.Views.GachaAnalysisWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:FufuLauncher.ViewModels"
    xmlns:models="using:FufuLauncher.Models"
    xmlns:converters="using:FufuLauncher.Converters"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    mc:Ignorable="d"
    Title="抽卡记录分析">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolInverter x:Key="BoolInverter"/>
            <SolidColorBrush x:Key="GridViewItemPointerOverBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="GridViewItemPressedBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="GridViewItemPointerOverBorderBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="GridViewItemSelectedBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="GridViewItemSelectedBorderBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="GridViewItemDragBackground" Color="Transparent"/>

            <DataTemplate x:Key="GachaCardTemplate" x:DataType="models:GachaDisplayItem">
                <Grid Width="110" Height="140" Margin="6" Translation="0,0,8"
                      Tapped="OnGachaCardTapped" PointerEntered="OnGridPointerEntered" PointerExited="OnGridPointerExited">
                    <primitives:FlyoutBase.AttachedFlyout>
                        <Flyout Placement="Right" ShowMode="Transient">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"/>
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <Grid Width="260" Padding="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.Background>
                                                <SolidColorBrush Color="{x:Bind RarityBackground.Color}" Opacity="0.3"/>
                                            </Grid.Background>
                                            <Image Source="{x:Bind ImageUrl, Mode=OneWay}" Stretch="UniformToFill" Height="60" Width="60"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                            <TextBlock Text="{x:Bind Rank}" Foreground="{x:Bind RarityColorHex}" FontWeight="Bold"/>
                                            <FontIcon Glyph="&#xE735;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{x:Bind RarityColorHex}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind Type}" FontSize="12" Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <MenuFlyoutSeparator Grid.Row="1" Margin="0,0,0,12"/>
                                <StackPanel Grid.Row="2" Spacing="8">
                                    <Grid>
                                        <TextBlock Text="花费抽数" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{x:Bind Count}" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                            <TextBlock Text="/ 90" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Height="16">
                                        <ProgressBar Value="{x:Bind Count}" Maximum="90" Minimum="0" 
                                                     Foreground="{x:Bind RarityColorHex}"
                                                     Background="{ThemeResource ControlStrongFillColorDefaultBrush}"
                                                     VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <TextBlock Text="获取时间" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Time}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Flyout>
                    </primitives:FlyoutBase.AttachedFlyout>

                    <ToolTipService.ToolTip>
                        <ToolTip Content="点击查看详细数据"/>
                    </ToolTipService.ToolTip>
                    <Grid.Shadow>
                        <ThemeShadow/>
                    </Grid.Shadow>
                    
                    <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.RowSpan="2">
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="Transparent" Offset="0.3"/>
                                        <GradientStop Color="{x:Bind RarityBackground.Color}" Offset="1.1"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                            </Grid>
                            <Image Grid.Row="0" Grid.RowSpan="2" Source="{x:Bind ImageUrl, Mode=OneWay}" 
                                   Stretch="UniformToFill" VerticalAlignment="Bottom" Margin="0,0,0,24"/>
                            <Image Source="{x:Bind ElementImageSource, Mode=OneWay}" Width="22" Height="22" 
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"/>
                            <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Opacity="0.97">
                                <StackPanel VerticalAlignment="Center" Padding="8,2">
                                    <TextBlock Text="{x:Bind Name}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Pity:" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind Count}" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}" 
                                    CornerRadius="0,8,0,4" Padding="6,2">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <TextBlock Text="{x:Bind Rank}" FontSize="10" FontWeight="Bold" Foreground="{x:Bind RarityColorHex}"/>
                                    <FontIcon Glyph="&#xE735;" FontFamily="Segoe Fluent Icons" FontSize="8" Foreground="{x:Bind RarityColorHex}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="PoolStatsHeaderTemplate" x:DataType="models:GachaStatistic">
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Translation="0,0,8"
                        CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="总抽数: " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind TotalCount}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="五星: " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind FiveStarCount}" FontWeight="Bold" Foreground="#FFD700"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="四星: " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind FourStarCount}" FontWeight="Bold" Foreground="#DDA0DD"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="五星垫: " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind CurrentPity}" FontWeight="Bold" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="四星垫: " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind CurrentPity4}" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </Grid.Resources>

        <Grid Margin="24,48,24,24">

            <!-- 加载中 -->
            <ProgressRing x:Name="LoadingRing" HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40"
                          IsActive="{Binding ViewModel.IsDataLoaded, Converter={StaticResource BoolInverter}}"/>

            <!-- 空状态：无抽卡记录 -->
            <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24"
                        Visibility="Collapsed">
                <StackPanel.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="40"/>
                    </TransitionCollection>
                </StackPanel.Transitions>
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE9D2;" FontSize="48" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock Text="获取抽卡记录" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="选择一种方式导入你的祈愿记录，开始分析你的抽卡数据" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <Button Click="OnMiYouSheLoginClick" HorizontalAlignment="Stretch" Padding="0">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE77B;" FontSize="32" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="通过米游社账号获取" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="通过当前登录的米游社&#x0a;账号直接获取记录" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Row="2" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                <TextBlock Text="推荐" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Click="OnUrlFetchClick" HorizontalAlignment="Stretch" Padding="0">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE71B;" FontSize="32" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="通过 URL 获取" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="粘贴抽卡分析链接&#x0a;从 API 拉取记录" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- 导入 UIGF 文件 -->
                    <Button Command="{x:Bind ViewModel.ImportUigfCommand}" HorizontalAlignment="Stretch" Padding="0">
                        <Grid Width="220" Height="160" Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE8B5;" FontSize="32" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="导入 UIGF 文件" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="从标准 UIGF v4.2 格式&#x0a;JSON 文件导入记录" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- 状态反馈 -->
                <StackPanel x:Name="EmptyStateStatusPanel" Spacing="8" HorizontalAlignment="Center"
                            Visibility="{Binding ViewModel.IsFetching, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="500"/>
                    <TextBlock x:Name="EmptyStateStatusText" Text="{x:Bind ViewModel.CrawlerStatus, Mode=OneWay}" Width="500"
                               HorizontalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- 已有记录：数据操作栏 + 卡池页面 -->
            <Grid Visibility="{Binding ViewModel.HasGachaData, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="UidComboBox"
                                  ItemsSource="{x:Bind ViewModel.UidComboItems}"
                                  SelectedItem="{x:Bind ViewModel.SelectedUid, Mode=TwoWay}"
                                  Width="150"
                                  IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}"
                                  SelectionChanged="OnUidComboBoxSelectionChanged"/>
                        <Button IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="更新数据"/>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="通过米游社账号获取" Click="OnMiYouSheLoginClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE77B;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="通过 URL 获取" Click="OnUrlFetchClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="导入 UIGF 文件" Command="{x:Bind ViewModel.ImportUigfCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ExportUigfCommand}"
                                IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                                <TextBlock Text="导出 UIGF"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.PreFetchMetadataCommand}"
                                IsEnabled="{Binding ViewModel.IsScraping, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B9;" FontSize="14"/>
                                <TextBlock Text="预下载图片"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnDeleteGachaDataClick"
                                IsEnabled="{Binding ViewModel.IsFetching, Converter={StaticResource BoolInverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                <TextBlock Text="删除记录"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <Grid>
                            <ProgressBar IsIndeterminate="True" HorizontalAlignment="Stretch" Visibility="{Binding ViewModel.IsFetching, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <ProgressBar IsIndeterminate="True" HorizontalAlignment="Stretch" Visibility="{Binding ViewModel.IsScraping, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.CrawlerStatus, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <Pivot Grid.Row="1">
                    <PivotItem Header="角色活动">
                        <ScrollViewer>
                            <StackPanel Padding="0,12,0,12" Spacing="16">
                                <ContentControl Content="{x:Bind ViewModel.CharacterStats, Mode=OneWay}" ContentTemplate="{StaticResource PoolStatsHeaderTemplate}"/>
                                <TextBlock Text="五星记录" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                                <GridView ItemsSource="{x:Bind ViewModel.CharacterFiveStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                                <MenuFlyoutSeparator/>
                                <TextBlock Text="四星记录" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,8"/>
                                <GridView ItemsSource="{x:Bind ViewModel.CharacterFourStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <PivotItem Header="武器活动">
                        <ScrollViewer>
                            <StackPanel Padding="0,12,0,12" Spacing="16">
                                <ContentControl Content="{x:Bind ViewModel.WeaponStats, Mode=OneWay}" ContentTemplate="{StaticResource PoolStatsHeaderTemplate}"/>
                                <TextBlock Text="五星记录" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <GridView ItemsSource="{x:Bind ViewModel.WeaponFiveStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                                <MenuFlyoutSeparator/>
                                <TextBlock Text="四星记录" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <GridView ItemsSource="{x:Bind ViewModel.WeaponFourStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <PivotItem Header="常驻祈愿">
                        <ScrollViewer>
                            <StackPanel Padding="0,12,0,12" Spacing="16">
                                <ContentControl Content="{x:Bind ViewModel.StandardStats, Mode=OneWay}" ContentTemplate="{StaticResource PoolStatsHeaderTemplate}"/>
                                <TextBlock Text="五星记录" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <GridView ItemsSource="{x:Bind ViewModel.StandardFiveStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                                <MenuFlyoutSeparator/>
                                <TextBlock Text="四星记录" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <GridView ItemsSource="{x:Bind ViewModel.StandardFourStars, Mode=OneWay}" ItemTemplate="{StaticResource GachaCardTemplate}" SelectionMode="None" IsItemClickEnabled="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <PivotItem Header="图片资源库">
                        <ScrollViewer>
                            <GridView ItemsSource="{x:Bind ViewModel.AllMetadataPreview, Mode=OneWay}" SelectionMode="None" Margin="0,12,0,0">
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ScrapedMetadata">
                                        <Grid Width="90" Height="110" Margin="4" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Image Source="{Binding ImgSrc}" Stretch="UniformToFill" Margin="0,0,0,24"/>
                                            <Image Source="{Binding ElementSrc}" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4"/>
                                            <Grid VerticalAlignment="Bottom" Height="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                                <TextBlock Text="{x:Bind Name}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Grid>
    </Grid>
</Window>